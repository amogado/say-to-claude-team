// message-template.json — Example payload.json structure (JSON5 format, comments allowed)
// Full file lives at: ~/.claude/team-queue/messages/<uuid>/payload.json
// This template is documentation only — actual payloads are generated by send.sh.
{
  // Unique message identifier. UUID v4 lowercase. Generated by uuidgen. Immutable once written.
  "id": "a1b2c3d4-e5f6-4789-abcd-ef0123456789",

  // ISO 8601 UTC timestamp set at send time. Used for TTL expiry and display ordering.
  "timestamp": "2026-04-10T22:00:00Z",

  "sender": {
    // Sender's bit-position in the registry bitmask (integer >= 0). Unique per active session.
    "bit": 0,

    // Human-readable session name as registered in registry.json (e.g. "backend", "frontend").
    "name": "my-session",

    // OS process ID of the sender's shell at send time.
    "pid": 12345,

    // Unix epoch seconds of the sender process start. Guards against PID recycling.
    "start_time": 1712345678
  },

  // Delivery target: "all" for broadcast, or an exact session name (e.g. "backend").
  "target": "all",

  // Message type:
  //   "text"    — informational, no action expected
  //   "command" — recipient should execute the instruction
  //   "query"   — recipient should reply (using in_reply_to)
  "type": "text",

  // UTF-8 message content. Keep to one subject per message.
  "body": "Hello team!",

  "metadata": {
    // Delivery priority: "normal" or "high". High-priority messages should use a short TTL.
    "priority": "normal",

    // Seconds until this message expires and becomes eligible for garbage collection.
    // Default: 3600 (1 hour). Set via TEAM_MSG_TTL env var before calling send.sh.
    "ttl_seconds": 3600
  },

  // UUID of the message being replied to, or null.
  // Set via TEAM_MSG_REPLY_TO env var before calling send.sh.
  "in_reply_to": null
}
